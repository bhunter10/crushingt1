# Step 1 — from Givebutter install script (?acct=...)
NEXT_PUBLIC_GIVEBUTTER_ACCOUNT_ID=your_givebutter_account_id

# Step 3 — from Form embed: <givebutter-widget id="pXv4q7"></givebutter-widget>
NEXT_PUBLIC_GIVEBUTTER_WIDGET_ID=your_widget_id

# Campaign code — six characters near the campaign title on the campaign edit page
NEXT_PUBLIC_GIVEBUTTER_CAMPAIGN_CODE=your_campaign_code

# Resend API for the contact form
# https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Optional: override sender/inbox
CONTACT_FROM=CrushingT1 Website <onboarding@resend.dev>
CONTACT_TO=crushingt1foundation@gmail.com
